# ERPNext Hetzner Deployment - Environment Variables
# Copy to .env and fill in values before deploying
# Reference: https://github.com/frappe/frappe_docker/blob/main/docs/02-setup/04-env-variables.md

# === REQUIRED ===

# ERPNext image version (match Railway: v16.15.1)
ERPNEXT_VERSION=v16.15.1

# MariaDB root password (generate a strong one)
DB_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD

# ERPNext admin password (for bench new-site)
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# Let's Encrypt email for TLS certificates
LETSENCRYPT_EMAIL=bryan@amdg.ai

# === TUNING (CX32 optimized) ===

# Gunicorn workers: 2 for CX32 (4 GB RAM)
# Reduce to 1 if RAM is tight, increase to 3 if you upgrade to CX42
GUNICORN_WORKERS=2

# Site name header - set to your domain
FRAPPE_SITE_NAME_HEADER=erp.talent.amdg.ai

# Upload size limit (resumes are typically <10MB)
CLIENT_MAX_BODY_SIZE=50m

# Proxy read timeout (seconds) - increase for slow reports
PROXY_READ_TIMEOUT=120

# === NETWORKING ===

# Set to Caddy's IP if using Caddy in front
UPSTREAM_REAL_IP_ADDRESS=127.0.0.1
UPSTREAM_REAL_IP_HEADER=X-Forwarded-For
UPSTREAM_REAL_IP_RECURSIVE=off
